# Credentials for resume-cold-read. Either export these in your shell or
# drop this file at ~/.config/resume-cold-read/.env (recommended) or in
# the CWD of your invocation. See `resume-cold-read doctor` to verify.

# Azure OpenAI — GPT-class vision models (the calibrated default shape).
# The endpoint is the Azure resource URL, ending in /openai.azure.com/
# for classic Azure OpenAI, or /cognitiveservices.azure.com/ for
# AI Foundry accounts.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure MaaS — Models-as-a-Service endpoints (Grok, Llama, DeepSeek, …).
# Accessed through the /openai/v1/ suffix on the Azure AI inference
# endpoint.
AZURE_MAAS_API_KEY=
AZURE_MAAS_ENDPOINT=
